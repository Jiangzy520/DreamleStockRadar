[Unit]
Description=Push CTP Futures Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/push_xtp_bridge
ExecStart=/home/ubuntu/push_xtp_bridge/.venv_install/bin/python /home/ubuntu/push_xtp_bridge/push_ctp_bridge.py --config /home/ubuntu/push_xtp_bridge/push_ctp_bridge.config.json
Restart=always
RestartSec=8
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
